{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": 2,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "title": "Active Simulation Runs",
      "type": "stat",
      "targets": [
        {
          "expr": "aabs_active_simulations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "title": "Total Simulated Agents",
      "type": "stat",
      "targets": [
        {
          "expr": "aabs_simulated_agents_count",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "title": "Simulation Tick Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(aabs_engine_ticks_total[1m]))",
          "legendFormat": "Ticks/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "cps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 4,
      "title": "Celery Task Throughput by Name",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total[5m])) by (name)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 5,
      "title": "Celery Queue Length backlog",
      "type": "timeseries",
      "targets": [
        {
          "expr": "celery_queue_length",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          }
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["aabs", "simulation", "celery"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "title": "AABS - Simulation & Task Engine Metrics",
  "version": 1
}
