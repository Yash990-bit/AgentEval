# Environment
ENV=production
NODE_ENV=production

# Database (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=simulator
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/simulator

# Redis (Cache, Celery broker and backend)
REDIS_URL=redis://redis:6379/0

# Vector DB (Qdrant)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Object Storage (MinIO / S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agentverse-snapshots
AWS_REGION=us-east-1

# Error Tracking (Sentry - replace with your actual keys on deployment)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=agentverse
SENTRY_PROJECT=aabs
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.1
