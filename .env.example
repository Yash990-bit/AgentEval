# Environment
ENV=production
NODE_ENV=production

# Database (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=simulator
DATABASE_URL=postgresql+psycopg2://postgres:your_secure_password@db:5432/simulator

# Redis (Cache, Celery broker and backend)
REDIS_URL=redis://redis:6379/0

# Vector DB (Qdrant)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Object Storage (MinIO / S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_secure_password
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=your_minio_secure_password
S3_BUCKET=agentverse-snapshots
AWS_REGION=us-east-1

# Error Tracking (Sentry)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/123456
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/123456
SENTRY_ORG=agentverse
SENTRY_PROJECT=aabs
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_TRACES_SAMPLE_RATE=0.1
